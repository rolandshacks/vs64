{
    "body": {
        "prefix": "BODY",
        "body": [
            ";",
            "; $TM_FILENAME_BASE",
            ";",
            "",
            "        *=\\$0801",
            "        .byte \\$0c,\\$08,\\$b5,\\$07,\\$9e,\\$20,\\$32,\\$30,\\$36,\\$32,\\$00,\\$00,\\$00",
            "        jmp start",
            "",
            "        start",
            "        rts",
            ""
        ],
        "description": "Assembler file body"
    },
    "body-with-macros": {
        "prefix": "BODYX",
        "body": [
            ";",
            "; $TM_FILENAME_BASE",
            ";",
            "        .include \"libmacro64.asm\"",
            "",
            "        #std_startup \\$0801, main",
            "",
            "; -------------------------------------------------",
            "; main",
            "; -------------------------------------------------",
            "",
            "main",
            "        rts",
            "",
            "; -------------------------------------------------",
            "; libraries",
            "; -------------------------------------------------",
            "",
            "        .include \"libstd64.asm\"",
            "        .include \"libvideo64.asm\"",
            ""
        ],
        "description": "Assembler file body using standard library"
    },
    "macro": {
        "prefix": "MACRO",
        "body": [
            "${1:name} .macro",
            "        $0",
            "        .endm"
        ],
        "description": "Macro declaration"
    },
    "comment-block": {
        "prefix": "COMMENT",
        "body": [
            "",
            "; -------------------------------------------------",
            "; $0",
            "; -------------------------------------------------",
            ""
        ],
        "description": "Comment block"
    },
    "comment-line": {
        "prefix": "LINE",
        "body": [
            "; -------------------------------------------------",
            ""
        ],
        "description": "Comment line"
    }
}
